<!DOCTYPE html>
<html>
<head>
<title> String Function </title>
</head>
<body>
<form name="PForm">
<br>
<h1> Count Vowel </h1>
<br>
Enter Your Name  : 
<input type=text name="t1" >
<br> <br>
<input type=button name="btn" value="Count Vowel" onClick="cntv()">

</form>
</body>
<script type="text/javascript">
function cntv()
{
var i,s,ch,c;
c=0;
s=PForm.t1.value;
for(i=0;i<=s.length;i++)
  {
      ch=s.charAt(i);
      if(ch=="A"|| ch=="a"||ch=="E"|| ch=="e"||ch=="I"|| ch=="i"||ch=="O"|| ch=="o"||ch=="U"|| ch=="u")
      c++;
   }
alert("Number of Vowels in Name are :  " +  c);
}

</script>
</html>
